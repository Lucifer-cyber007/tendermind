GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
POSTGRES_USER=tendermind
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=tendermind
DATABASE_URL=postgresql+asyncpg://tendermind:your_password@postgres:5432/tendermind
DATABASE_URL_SYNC=postgresql://tendermind:your_password@postgres:5432/tendermind
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=your_minio_secret_here
S3_BUCKET=tendermind-docs
S3_REGION=us-east-1
SECRET_KEY=your_64_char_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
APP_ENV=development
